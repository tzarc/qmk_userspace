#!/usr/bin/env zsh
# vim:ft=sh ts=4 sw=4 sts=4

set -eEuo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"

exec bwrap-run \
    --app-bin claude \
    --rw-app "$REPO_ROOT" \
    --rw-app "$TZ_DOTFILES/extra/ai-shenanigans" \
    --rw-app "$HOME/.claude" \
    --rw-app "$HOME/.claude.json" \
    --rw-app "$HOME/.claude-mem" \
    --setenv "VSCODE_PID=" \
    --setenv "VSCODE_CWD=" \
    --setenv "TERM_PROGRAM=" \
    -- \
    "$(command -v claude)" --dangerously-skip-permissions "$@"
